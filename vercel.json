{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.bubudroid.me/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/gfm",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/bday",
      "schedule": "5 0 * * *"
    }
  ]
}
